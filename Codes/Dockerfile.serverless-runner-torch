FROM serverless-runner:ubuntu22

# Match the SeBS 411.image-recognition Python 3.10 dependency set closely enough
# to run the benchmark inside the local runner image.
RUN pip3 install --no-cache-dir \
    "numpy==1.22.0" \
    "https://download.pytorch.org/whl/cpu/torch-1.11.0%2Bcpu-cp310-cp310-linux_x86_64.whl" \
    "https://download.pytorch.org/whl/cpu/torchvision-0.12.0%2Bcpu-cp310-cp310-linux_x86_64.whl"
